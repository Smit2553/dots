{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high"
    },
    "general": {
      "model": "openai/gpt-5.4-mini",
      "variant": "xhigh"
    },
    "scout": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "variant": "high"
    },
    "backend-architect": {
      "mode": "subagent"
    },
    "code-reviewer": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "variant": "xhigh",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "frontend-developer": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "variant": "xhigh"
    },
    "minimal-change-engineer": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "variant": "xhigh"
    },
    "security-architect": {
      "mode": "subagent"
    },
    "software-architect": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "variant": "xhigh"
    },
    "technical-writer": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini",
      "variant": "xhigh"
    }
  }
}
